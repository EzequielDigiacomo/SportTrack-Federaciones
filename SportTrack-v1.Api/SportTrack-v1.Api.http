@SportTrack_v1.Api_HostAddress = http://localhost:5029

### AUTHENTICATION ###

# 1. Register a new Club User
POST {{SportTrack_v1.Api_HostAddress}}/api/auth/register
Content-Type: application/json

{
  "username": "club_nautico",
  "password": "Password123!",
  "email": "contacto@nautico.com",
  "rol": "Club"
}

###

# 2. Login
# @name login
POST {{SportTrack_v1.Api_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "username": "club_nautico",
  "password": "Password123!"
}

###

@token = {{login.response.body.token}}

### CLUBES ###

# 2.1 Create a new Club
POST {{SportTrack_v1.Api_HostAddress}}/api/clubes
Content-Type: application/json

{
  "nombre": "Club Nautico San Pedro",
  "sigla": "CNSP",
  "email": "nautico@sanpedro.com",
  "ubicacion": "San Pedro, Buenos Aires"
}

###

### EVENTS ###

# 3. Get all events
GET {{SportTrack_v1.Api_HostAddress}}/api/eventos
Accept: application/json

###

# 4. Get upcoming events (Dashboard)
GET {{SportTrack_v1.Api_HostAddress}}/api/eventos/proximos
Accept: application/json

### PARTICIPANTS (ATHLETES) ###

# 5. Create a new athlete (Requires Auth)
POST {{SportTrack_v1.Api_HostAddress}}/api/participantes
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "nombre": "Juan",
  "apellido": "Perez",
  "fechaNacimiento": "2005-05-20",
  "sexoId": 1,
  "clubId": 1,
  "pais": "Argentina"
}

###

# 6. Get athletes by club
GET {{SportTrack_v1.Api_HostAddress}}/api/participantes/club/1
Accept: application/json

### INSCRIPTIONS ###

# 7. Create an inscription for an event (Requires Auth)
POST {{SportTrack_v1.Api_HostAddress}}/api/inscripciones
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "eventoPruebaId": 1,
  "participanteId": 1,
  "numeroCompetidor": "100",
  "carril": 4
}

### RESULTS (REAL-TIME) ###

# 8. Upsert a result (Trigger SignalR)
POST {{SportTrack_v1.Api_HostAddress}}/api/resultados/upsert
Content-Type: application/json

{
  "inscripcionId": 1,
  "tiempoOficial": "00:01:45.500",
  "posicion": 1,
  "puntos": 10.0,
  "estado": "Finalizado"
}

###

# 9. Get results for a specific race
GET {{SportTrack_v1.Api_HostAddress}}/api/resultados/prueba/1
Accept: application/json
